# ─────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# Reverse proxy / HTTPS behavior
# TRUST_PROXY=true enables Express proxy awareness (needed behind Nginx/ALB)
TRUST_PROXY=false
# FORCE_HTTPS=true redirects all non-HTTPS requests to HTTPS
FORCE_HTTPS=false

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
JWT_SECRET=replace_with_minimum_32_char_random_string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_different_minimum_32_char_string
JWT_REFRESH_EXPIRES_IN=30d
# JWT blacklist store mode: memory | redis | auto
#  - memory: always in-memory blacklist (dev-friendly)
#  - redis: require Redis; startup fails if unavailable
#  - auto: use Redis when REDIS_URL is set, else fallback to memory
JWT_BLACKLIST_STORE=auto

# Redis URL (required if JWT_BLACKLIST_STORE=redis)
# Example: redis://localhost:6379
REDIS_URL=

# ─────────────────────────────────────────────
# DATABASE (pending client decision — uncomment one)
# ─────────────────────────────────────────────
# Option A — MongoDB
# MONGODB_URI=mongodb://localhost:27017/bricks

# Option B — PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/bricks

# ─────────────────────────────────────────────
# CLOUDINARY
# ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─────────────────────────────────────────────
# SMS GATEWAY (OTP delivery — pick ONE)
# ─────────────────────────────────────────────

# Option A — MSG91 (recommended for India)
# Get authkey from: https://control.msg91.com
# Create an OTP template in MSG91 dashboard with {{OTP}} variable
MSG91_AUTH_KEY=your_msg91_authkey
MSG91_TEMPLATE_ID=your_msg91_template_id

# Option B — Twilio (international)
# Get credentials from: https://console.twilio.com
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE=+1XXXXXXXXXX

# ─────────────────────────────────────────────
# ADMIN SEEDER
# ─────────────────────────────────────────────
ADMIN_PHONE=+919876543210

# ─────────────────────────────────────────────
# FIREBASE ADMIN (for OTP — Path B only)
# Only needed if you use Firebase Phone Auth on the frontend
# ─────────────────────────────────────────────
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_key_here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# ─────────────────────────────────────────────
# EMAIL — Nodemailer (SMTP)
# ─────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
EMAIL_FROM=Mumbai Editorial <no-reply@mumbaieditorial.com>

# ─────────────────────────────────────────────
# EMAIL — SendGrid (alternative to Nodemailer)
# ─────────────────────────────────────────────
SENDGRID_API_KEY=SG.your_sendgrid_api_key

# ─────────────────────────────────────────────
# ADMIN
# ─────────────────────────────────────────────
ADMIN_EMAIL=admin@mumbaieditorial.com

# ─────────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
