    {
      "name": "1 - Auth",
      "item": [
        {
          "name": "POST /api/auth/login (user)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"{{userIdentifier}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200/401/403 (depends on configured credentials)', function () {",
                  "  pm.expect([200, 401, 403]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  const token = json && json.data && json.data.accessToken;",
                  "  if (token) pm.environment.set('userAccessToken', token);",
                  "}"
                ]
              }
            }
          ]
        },
