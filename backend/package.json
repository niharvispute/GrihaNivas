{
  "name": "bricks-backend",
  "version": "1.0.0",
  "description": "Mumbai Editorial — Real Estate Platform Backend",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "preflight:prod": "node scripts/preflight-prod.js",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.js\"",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop bricks-backend",
    "pm2:restart": "pm2 restart bricks-backend",
    "pm2:logs": "pm2 logs bricks-backend",
    "seed:admin": "node scripts/seedAdmin.js",
    "seed:builders": "node scripts/seedBuilders.js",
    "test:apis": "node scripts/test-apis.js",
    "test:builders": "node scripts/test-apis.js --scope=builders",
    "test:auth:v2": "node scripts/test-auth-v2.js",
    "migrate:property-lifecycle": "node scripts/migratePropertyLifecycle.js",
    "cleanup:rejected-properties": "node scripts/cleanupRejectedProperties.js"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.3",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.0",
    "firebase-admin": "^13.1.0",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.4.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.9.16",
    "redis": "^4.7.0",
    "slugify": "^1.6.6",
    "xss-clean": "^0.1.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "nodemon": "^3.1.9",
    "prettier": "^3.4.2"
  }
}
